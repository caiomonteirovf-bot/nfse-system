# Banco de dados (SQLite local por padrao, PostgreSQL para producao)
DATABASE_URL=sqlite:///./data/nfse.db
# DATABASE_URL=postgresql://user:pass@host:5432/nfse_db

# ABRASF - Dados do Prestador (fallback se nao configurado no DB)
NFSE_PRESTADOR_CNPJ=00000000000000
NFSE_INSCRICAO_MUNICIPAL=
NFSE_RAZAO_SOCIAL=Minha Empresa LTDA
NFSE_MUNICIPIO_CODIGO=3550308

# ABRASF - Webservice
NFSE_WEBSERVICE_URL=https://nfse.prefeitura.gov.br/webservice
NFSE_AMBIENTE=HOMOLOGACAO

# Nuvem Fiscal API (recomendado — abstrai ABRASF/SEFIN)
NUVEM_FISCAL_CLIENT_ID=
NUVEM_FISCAL_CLIENT_SECRET=
NUVEM_FISCAL_AMBIENTE=homologacao
